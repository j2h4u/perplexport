{
  "name": "perplexport",
  "version": "2.1.0",
  "description": "Export Perplexity conversations as markdown files",
  "main": "dist/cli.js",
  "bin": {
    "perplexport": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "if [ -f dist/cli.js ]; then chmod +x dist/cli.js; fi"
  },
  "keywords": [
    "perplexity",
    "export",
    "markdown",
    "cli",
    "conversation",
    "backup",
    "automation"
  ],
  "author": "j2h4u",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "puppeteer": "^24.9.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/j2h4u/perplexport.git"
  },
  "bugs": {
    "url": "https://github.com/j2h4u/perplexport/issues"
  },
  "homepage": "https://github.com/j2h4u/perplexport#readme"
}
